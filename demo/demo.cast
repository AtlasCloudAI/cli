{"version":2,"width":96,"height":28,"timestamp":1778642770,"command":"./demo/demo.sh","env":{"SHELL":"/bin/zsh"}}
[0.100000, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.200000, "o", "\u001b[1;37mAtlasCloud CLI\u001b[0m\r\nCall Atlas Cloud LLM, image, video, and audio APIs from your shell.\r\n\r\n"]
[1.000000, "o", "\u001b[1;36m$\u001b[0m atlas version\r\natlas-cli v0.1.15\r\n\r\n"]
[2.000000, "o", "\u001b[1;36m$\u001b[0m atlas models --help\r\n"]
[2.100000, "o", "Discover AtlasCloud models.\r\n\r\nExamples:\r\n  atlas models list --type chat\r\n  atlas models list --type image\r\n  atlas models list --type video\r\n  atlas models search nano --type image\r\n  atlas models get google/nano-banana-2/text-to-image\r\n\r\nUsage:\r\n  atlas models [command]\r\n\r\nAvailable Commands:\r\n  get         Get full parameter schema for a model\r\n  list        List available models\r\n  search      Search models by keyword\r\n\r\nFlags:\r\n  -h, --help   help for models\r\n\r\nGlobal Flags:\r\n      --json       force JSON output (auto-on for non-TTY)\r\n      --no-color   disable colors (also via NO_COLOR env)\r\n  -q, --quiet      suppress spinners and progress text\r\n  -v, --verbose    verbose debug output to stderr\r\n\r\nUse \"atlas models [command] --help\" for more information about a command.\r\n\r\n"]
[3.000000, "o", "\u001b[1;36m$\u001b[0m atlas generate image --help\r\n"]
[3.100000, "o", "Generate an image\r\n\r\nUsage:\r\n  atlas generate image MODEL -p PROMPT [flags]\r\n\r\nFlags:\r\n      --aspect-ratio string      aspect ratio: 1:1, 16:9, 9:16, 4:3, 3:4 (default \"1:1\")\r\n  -h, --help                     help for image\r\n      --image string             input image: URL, @file, or @data:base64...\r\n      --interval duration        poll interval (default 2s)\r\n      --negative-prompt string   negative prompt\r\n      --no-download              don't download outputs (just print URLs)\r\n      --no-wait                  return prediction_id immediately\r\n  -o, --output string            download path (default: ./pred_<id>_<i>.<ext>)\r\n  -p, --prompt string            prompt text (required)\r\n      --seed int                 random seed\r\n      --timeout duration         max wait duration (default 5m0s)\r\n      --wait                     wait for completion (default true)\r\n\r\nGlobal Flags:\r\n      --json       force JSON output (auto-on for non-TTY)\r\n      --no-color   disable colors (also via NO_COLOR env)\r\n  -q, --quiet      suppress spinners and progress text\r\n  -v, --verbose    verbose debug output to stderr\r\n\r\n"]
[4.000000, "o", "\u001b[1;36m$\u001b[0m atlas generate image google/nano-banana-2/text-to-image -p \"...\" --no-wait --json\r\n"]
[4.100000, "o", "\u001b[2m# Authenticate once with: atlas auth login\u001b[0m\r\n\u001b[2m# Use models list/get and generate cost before billable calls.\u001b[0m\r\n\r\n"]
[5.000000, "o", "\u001b[1;32mReady:\u001b[0m curl -fsSL https://raw.githubusercontent.com/AtlasCloudAI/cli/main/install.sh | sh\r\n"]
[6.000000, "x", "0"]
