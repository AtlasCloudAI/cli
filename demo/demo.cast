[15.157353, "o", "\r\n"]
[15.172626, "o", "Generate an image\r\n\r\nUsage:\r\n  atlas generate image MODEL -p PROMPT [flags]\r\n\r\nFlags:\r\n      --aspect-ratio string      aspect ratio: 1:1, 16:9, 9:16, 4:3, 3:4 (default \"1:1\")\r\n  -h, --help                     help for image\r\n      --image string             input image: URL, @file, or @data:base64...\r\n      --interval duration        poll interval (default 2s)\r\n      --negative-prompt string   negative prompt\r\n      --no-download              don't download outputs (just print URLs)\r\n      --no-wait                  return prediction_id immediately\r\n  -o, --output string            download path (default: ./pred_<id>_<i>.<ext>)\r\n  -p, --prompt string            prompt text (required)\r\n      --seed int                 random seed\r\n      --timeout duration         max wait duration (default 5m0s)\r\n      --wait                     wait for completion (default true)\r\n\r\nGlobal Flags:\r\n      --json       force JSON output (auto-on for non-TTY)\r\n      --no-color   disable colors (also via NO_COLOR env)\r\n  -q, --qui"]
[15.172671, "o", "et      suppress spinners and progress text\r\n  -v, --verbose    verbose debug output to stderr\r\n"]
[15.173424, "o", "\r\n"]
