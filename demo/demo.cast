[0.737927, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.7417, "o", "\u001b[1;37mAtlasCloud CLI\u001b[0m\r\nCall LLM, image, and video models from your shell.\r\n\r\n"]
