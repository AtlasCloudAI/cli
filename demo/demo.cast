[8.351357, "o", "\u001b]11;?\u001b\\\u001b[6n"]
[13.357413, "o", "atlas — call AtlasCloud's 100+ LLM, image, and video models from your shell.\r\n\r\nQuick start:\r\n  atlas auth login\r\n  atlas chat \"explain UUID v7\"\r\n  atlas generate image google/nano-banana-2/text-to-image -p \"a cat\"\r\n  atlas models list --type image\r\n\r\n"]
[13.357422, "o", "Usage:\r\n  atlas [command]\r\n\r\nAvailable Commands:\r\n  account     Show account info and balance\r\n  auth        Manage authentication\r\n  chat        Send a chat completion to any LLM\r\n  completion  Generate the autocompletion script for the specified shell\r\n  generate    Generate images, videos, and check task status\r\n  help        Help about any command\r\n  models      Discover models\r\n  version     Show atlas-cli version\r\n\r\nFlags:\r\n  -h, --help       help for atlas\r\n      --json       force JSON output (auto-on for non-TTY)\r\n      --no-color   disable colors (also via NO_COLOR env)\r\n  -q, --quiet      suppress spinners and progress text\r\n  -v, --verbose    verbose debug output to stderr\r\n      --version    version for atlas\r\n\r\nUse \"atlas [command] --help\" for more information about a command.\r\n"]
[13.357663, "o", "\r\n"]
[14.166581, "o", "\u001b[1;36m$\u001b[0m "]
